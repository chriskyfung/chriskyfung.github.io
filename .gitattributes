# Set default behavior to automatically normalize line endings
* text=auto

# Force LF for JSON and other text files
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.html text eol=lf
*.js   text eol=lf
*.css  text eol=lf
*.ts   text eol=lf

# Images and binaries should be treated as binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.svg  text
*.woff2 binary
*.woff  binary
*.ttf   binary
*.eot   binary
*.ico   binary
